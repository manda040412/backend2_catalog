APP_NAME="Timur Raya Catalog"
APP_ENV=local
APP_KEY=  # ← Jalankan: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=e-catalog
DB_USERNAME=root
DB_PASSWORD=

# ── Cache & Session ────────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# ── Mail untuk 2FA OTP ─────────────────────────────────────────────
# Development: pakai MAIL_MAILER=log → kode muncul di storage/logs/laravel.log
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@timurraya.com"
MAIL_FROM_NAME="${APP_NAME}"

# Production: ganti ke SMTP asli, contoh Mailtrap:
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=isi_dari_mailtrap
# MAIL_PASSWORD=isi_dari_mailtrap
# MAIL_ENCRYPTION=tls

# ── Sanctum (CORS) ─────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000
FRONTEND_URL=http://localhost:5173
